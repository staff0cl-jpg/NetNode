PORT=3000
NODE_ENV=production

# If set, the first-run web wizard is skipped and PostgreSQL is used immediately.
# Example: postgres://user:password@localhost:5432/netnode
# DATABASE_URL=

# Optional RabbitMQ (AMQP 0-9-1), e.g. amqp://user:pass@localhost:5672/
# AMQP_URL=

# Optional Redis for shared cookie sessions (multiple app instances). Same as REDIS_URL.
# NETNODE_REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Skip wizard and run without PostgreSQL (in-memory only; not for production).
# NETNODE_SKIP_SETUP=1

# Optional: seed a local admin when DATABASE_URL is already set (required for empty DB when wizard is bypassed).
# NETNODE_INITIAL_ADMIN_PASSWORD=
# NETNODE_INITIAL_ADMIN_USERNAME=admin

# Dev only: recreate well-known accounts admin/admin and operator_01/password when DATABASE_URL is set.
# Never use in production or shared environments.
# NETNODE_ALLOW_INSECURE_DEV_USERS=1

# Max failed login attempts per client IP per 15-minute window (default 40).
# NETNODE_LOGIN_RATE_LIMIT_MAX=40

# Background SNMP refresh for inventory rows (ms). GET /api/inventory does not block on SNMP.
# Clamped 30000–600000; default 90000.
# NETNODE_INVENTORY_SNMP_INTERVAL_MS=90000

# SSH terminal proxy (per browser tab): max concurrent shells (1–32, default 8).
# NETNODE_SSH_MAX_SESSIONS_PER_TAB=8

# Close idle SSH shell after no user input and no data from remote (ms). Clamped 60000–14400000; default 1800000 (30m).
# NETNODE_SSH_IDLE_MS=1800000

# Max in-memory cookie sessions (default 10000). Oldest entries evicted when full after pruning expired.
# NETNODE_SESSION_STORE_MAX=10000

# If set (min 8 chars), SSH readonly profile passwords are AES-256-GCM sealed in RAM instead of plaintext.
# NETNODE_CREDENTIALS_KEY=

# Max JSON request body size for Express (MB). Clamped 0.25–5; default 1.
# NETNODE_JSON_BODY_LIMIT_MB=1

# Concurrent devices during background SNMP inventory refresh (1–64, default 16).
# NETNODE_INVENTORY_SNMP_CONCURRENCY=16

# Discovery: max IPs parsed from subnets (64–16384, default 1024) and worker concurrency (4–128, default 32).
# NETNODE_DISCOVERY_MAX_IPS=1024
# NETNODE_DISCOVERY_CONCURRENCY=32

# Set to 1 only for automated tests or emergencies — disables CSRF checks on mutating /api/* calls.
# NETNODE_CSRF_DISABLED=0
