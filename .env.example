PORT=3000
NODE_ENV=production

# If set, the first-run web wizard is skipped and PostgreSQL is used immediately.
# Example: postgres://user:password@localhost:5432/netnode
# DATABASE_URL=

# Optional RabbitMQ (AMQP 0-9-1), e.g. amqp://user:pass@localhost:5672/
# AMQP_URL=

# Skip wizard and run without PostgreSQL (in-memory only; not for production).
# NETNODE_SKIP_SETUP=1

# Optional: seed a local admin when DATABASE_URL is already set (required for empty DB when wizard is bypassed).
# NETNODE_INITIAL_ADMIN_PASSWORD=
# NETNODE_INITIAL_ADMIN_USERNAME=admin

# Dev only: recreate well-known accounts admin/admin and operator_01/password when DATABASE_URL is set.
# Never use in production or shared environments.
# NETNODE_ALLOW_INSECURE_DEV_USERS=1

# Max failed login attempts per client IP per 15-minute window (default 40).
# NETNODE_LOGIN_RATE_LIMIT_MAX=40
